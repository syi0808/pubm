{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["packages/pubm/package.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "bin/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "check": {},
    "coverage": {
      "dependsOn": ["^build"]
    }
  }
}
