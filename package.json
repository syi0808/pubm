{
  "name": "pubm-monorepo",
  "version": "0.3.6",
  "private": true,
  "engines": {
    "node": ">=24",
    "git": ">=2.11.0"
  },
  "description": "publish manager for multiple registry (jsr, npm and private registries)",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "packages/plugins/*",
    "packages/pubm/platforms/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "format": "biome check --write",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "coverage": "turbo run coverage",
    "dev:site": "cd website && pnpm dev",
    "build:site": "cd website && pnpm build",
    "preview:site": "cd website && pnpm preview",
    "release": "pubm --mode ci --phase prepare",
    "release:ci": "pubm --mode ci --phase publish",
    "demo": "bun demo/run.ts",
    "demo:single": "bun demo/run.ts --single"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@napi-rs/keyring-darwin-arm64": "1.2.0",
    "@napi-rs/keyring-darwin-x64": "1.2.0",
    "@napi-rs/keyring-linux-arm64-gnu": "1.2.0",
    "@napi-rs/keyring-linux-arm64-musl": "1.2.0",
    "@napi-rs/keyring-linux-x64-gnu": "1.2.0",
    "@napi-rs/keyring-linux-x64-musl": "1.2.0",
    "@napi-rs/keyring-win32-arm64-msvc": "1.2.0",
    "@napi-rs/keyring-win32-x64-msvc": "1.2.0",
    "@pubm/core": "workspace:^",
    "@pubm/darwin-arm64": "workspace:^",
    "@pubm/darwin-x64": "workspace:^",
    "@pubm/linux-arm64": "workspace:^",
    "@pubm/linux-x64": "workspace:^",
    "@pubm/plugin-brew": "workspace:^",
    "@pubm/plugin-external-version-sync": "workspace:^",
    "@pubm/windows-x64": "workspace:^",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "@vitest/coverage-istanbul": "4.0.18",
    "jsr": "^0.14.3",
    "pubm": "workspace:^",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "patchedDependencies": {
    "listr2@10.2.1": "patches/listr2.patch"
  }
}
