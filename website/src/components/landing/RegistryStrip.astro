---
---

<section class="registry-hub section-divider">
  <div class="container">
    <div class="hub-header fade-in-up">
      <div class="header-badge">Connectivity</div>
      <h2 class="display-title">One Hub, <span class="text-glow">Every Registry.</span></h2>
      <p class="header-desc">
        Pubm acts as a smart proxy for your distribution, handling authentication 
        and protocol differences across all major package ecosystems.
      </p>
    </div>

    <div class="hub-visual fade-in-up">
      <!-- Background Ambient Glow -->
      <div class="ambient-glow"></div>
      
      <!-- Central Core -->
      <div class="core-node">
        <div class="core-inner">
          <img src="/logo.svg" alt="pubm" width="48" height="48" />
        </div>
        <div class="core-rings">
          <div class="ring"></div>
          <div class="ring"></div>
        </div>
      </div>

      <!-- Registry Cards (Floating around core) -->
      <div class="registry-cards">
        <div class="reg-card npm" style="--angle: -140deg; --dist: 220px;">
          <div class="reg-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H4v4H1.334v-5.332h5.332v5.332zm6.668 0h-1.334v-5.332h5.334v5.332h-1.334v-4h-1.334v4h-1.332v-4h-1.334v4zm8 0h-1.334v-4h-1.334v4h-1.334v-5.332H21.334v5.332z"/></svg>
          </div>
          <div class="reg-info">
            <span class="reg-name">npm</span>
            <span class="reg-status">Connected</span>
          </div>
        </div>

        <div class="reg-card jsr" style="--angle: -40deg; --dist: 240px;">
          <div class="reg-icon jsr-icon">JSR</div>
          <div class="reg-info">
            <span class="reg-name">JSR.io</span>
            <span class="reg-status">Ready</span>
          </div>
        </div>

        <div class="reg-card crates" style="--angle: 40deg; --dist: 220px;">
          <div class="reg-icon crates-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="reg-info">
            <span class="reg-name">Crates.io</span>
            <span class="reg-status">Connected</span>
          </div>
        </div>

        <div class="reg-card private" style="--angle: 140deg; --dist: 240px;">
          <div class="reg-icon private-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          </div>
          <div class="reg-info">
            <span class="reg-name">Enterprise</span>
            <span class="reg-status">Private</span>
          </div>
        </div>
      </div>

      <!-- Connecting Beams (Visual only) -->
      <div class="beams-container">
        <div class="beam b1"></div>
        <div class="beam b2"></div>
        <div class="beam b3"></div>
        <div class="beam b4"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .registry-hub {
    padding: 12rem 1.5rem;
    overflow: hidden;
    background: #000; /* Deep black for higher contrast */
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .hub-header {
    text-align: center;
    margin-bottom: 8rem;
  }

  .header-badge {
    display: inline-block;
    color: var(--accent-cyan);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 1.5rem;
    background: rgba(6, 182, 212, 0.1);
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(6, 182, 212, 0.2);
  }

  .display-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .text-glow {
    color: var(--text-primary);
    text-shadow: 0 0 30px rgba(255, 255, 255, 0.2);
  }

  .header-desc {
    color: var(--text-muted);
    font-size: 1.25rem;
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Visual Core */
  .hub-visual {
    position: relative;
    height: 600px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ambient-glow {
    position: absolute;
    width: 600px;
    height: 400px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.08) 0%, transparent 70%);
    filter: blur(80px);
    z-index: 0;
  }

  .core-node {
    position: relative;
    z-index: 10;
  }

  .core-inner {
    width: 100px;
    height: 100px;
    background: #000;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 30px;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 0 50px rgba(0, 0, 0, 0.8), inset 0 0 20px rgba(255, 255, 255, 0.05);
    transform: rotate(15deg);
    transition: transform 0.5s ease;
  }

  .core-node:hover .core-inner {
    transform: rotate(0deg) scale(1.05);
    border-color: var(--accent-cyan);
  }

  .core-rings .ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    pointer-events: none;
  }

  .ring:nth-child(1) { width: 300px; height: 300px; }
  .ring:nth-child(2) { width: 500px; height: 500px; opacity: 0.5; }

  /* Registry Cards */
  .reg-card {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(
      calc(cos(var(--angle)) * var(--dist) - 50%),
      calc(sin(var(--angle)) * var(--dist) - 50%)
    );
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    padding: 0.75rem 1rem;
    border-radius: 16px;
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 160px;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 15;
  }

  .reg-card:hover {
    border-color: rgba(255, 255, 255, 0.3);
    transform: translate(
      calc(cos(var(--angle)) * (var(--dist) + 10px) - 50%),
      calc(sin(var(--angle)) * (var(--dist) + 10px) - 50%)
    ) scale(1.05);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .reg-icon {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 10px;
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--text-primary);
  }

  .reg-icon svg { width: 20px; height: 20px; }
  .jsr-icon { font-weight: 900; font-size: 0.7rem; color: #f7df1e; }
  
  .reg-info {
    display: flex;
    flex-direction: column;
  }

  .reg-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .reg-status {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  /* Beams */
  .beams-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5;
  }

  .beam {
    position: absolute;
    top: 50%;
    left: 50%;
    height: 1px;
    background: linear-gradient(90deg, var(--accent-cyan), transparent);
    transform-origin: left center;
    opacity: 0.2;
  }

  .b1 { width: 220px; transform: rotate(-140deg); }
  .b2 { width: 240px; transform: rotate(-40deg); }
  .b3 { width: 220px; transform: rotate(40deg); }
  .b4 { width: 240px; transform: rotate(140deg); }

  @media (max-width: 768px) {
    .hub-visual { height: auto; padding: 4rem 0; }
    .core-node, .ring, .beams-container { display: none; }
    .registry-cards {
      position: relative;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      width: 100%;
    }
    .reg-card {
      position: static;
      transform: none !important;
      min-width: 0;
    }
  }
</style>
