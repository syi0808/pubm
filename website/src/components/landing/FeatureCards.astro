---
import type { LandingDictionary } from "../../i18n/landing";

interface Props {
  copy: LandingDictionary;
}

const { copy } = Astro.props;
const [first, second, third, fourth] = copy.features.items;
---

<section class="features section-divider" id="features">
  <div class="features-container">
    <div class="features-header">
      <h2 class="gradient-text reveal-feature">{copy.features.title}</h2>
      <p class="reveal-feature">{copy.features.description}</p>
    </div>
    <div class="features-grid">
      <div class="feature-card reveal-card" data-accent="cyan" style="--card-accent: var(--accent-cyan);">
        <div class="feature-icon-wrapper">
          <svg class="feature-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
            <path d="M5 3v4M3 5h4M19 17v4M17 19h4"/>
          </svg>
        </div>
        <h3 class="feature-title">{first.title}</h3>
        <p class="feature-desc">{first.description}</p>
      </div>

      <div class="feature-card reveal-card" data-accent="green" style="--card-accent: var(--accent-green);">
        <div class="feature-icon-wrapper">
          <svg class="feature-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
            <path d="M3 3v5h5"/>
            <path d="m12 7 0 5 3 2"/>
          </svg>
        </div>
        <h3 class="feature-title">{second.title}</h3>
        <p class="feature-desc">{second.description}</p>
      </div>

      <div class="feature-card reveal-card" data-accent="violet" style="--card-accent: var(--accent-violet);">
        <div class="feature-icon-wrapper">
          <svg class="feature-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </div>
        <h3 class="feature-title">{third.title}</h3>
        <p class="feature-desc">{third.description}</p>
      </div>

      <div class="feature-card reveal-card" data-accent="cyan" style="--card-accent: var(--accent-cyan);">
        <div class="feature-icon-wrapper">
          <svg class="feature-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 17h16M4 13h16M4 9h16M4 5h16"/>
            <path d="m20 19-3-3 3-3"/>
          </svg>
        </div>
        <h3 class="feature-title">{fourth.title}</h3>
        <p class="feature-desc">{fourth.description}</p>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initFeatures() {
    const cards = gsap.utils.toArray<HTMLElement>('.reveal-card');
    const headers = gsap.utils.toArray<HTMLElement>('.reveal-feature');
    
    if (cards.length === 0) return;

    gsap.set(headers, { opacity: 0, y: 30 });
    gsap.set(cards, { opacity: 0, y: 40, rotateX: 5 });

    headers.forEach(header => {
      gsap.to(header, {
        scrollTrigger: {
          trigger: header,
          start: 'top 90%',
        },
        opacity: 1,
        y: 0,
        duration: 1,
        ease: 'power3.out'
      });
    });

    ScrollTrigger.batch(cards, {
      start: 'top 85%',
      onEnter: (batch) => gsap.to(batch, {
        opacity: 1,
        y: 0,
        rotateX: 0,
        stagger: 0.1,
        duration: 0.8,
        ease: 'power3.out',
        overwrite: true
      })
    });

    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        // @ts-ignore
        card.style.setProperty('--mouse-x', `${x}px`);
        // @ts-ignore
        card.style.setProperty('--mouse-y', `${y}px`);

        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = ((y - centerY) / centerY) * -6;
        const rotateY = ((x - centerX) / centerX) * 6;

        gsap.to(card, {
          rotateX: rotateX,
          rotateY: rotateY,
          scale: 1.01,
          duration: 0.4,
          ease: 'power2.out',
          overwrite: true
        });
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          scale: 1,
          duration: 0.6,
          ease: 'power2.out',
          overwrite: true
        });
      });
    });
  }

  if (document.readyState === 'complete') {
    initFeatures();
  } else {
    window.addEventListener('load', initFeatures);
  }
  document.addEventListener('astro:after-swap', initFeatures);
</script>

<style>
  .features {
    padding: 12rem 1.5rem;
    display: flex;
    justify-content: center;
    background: radial-gradient(circle at 50% 0%, rgba(34, 211, 238, 0.05) 0%, transparent 60%);
  }

  .features-container {
    max-width: 1200px;
    width: 100%;
  }

  .features-header {
    text-align: center;
    margin-bottom: 6rem;
  }

  .features-header h2 {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .features-header p {
    color: var(--text-muted);
    font-size: clamp(1.1rem, 1.5vw, 1.25rem);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    perspective: 1200px;
  }

  .feature-card {
    background: var(--bg-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 3rem;
    position: relative;
    overflow: hidden;
    transform-style: preserve-3d;
    will-change: transform;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), 
                rgba(255, 255, 255, 0.08), transparent 40%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
  }

  .feature-card:hover {
    border-color: var(--border-bright);
    box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.5);
  }

  .feature-card:hover::before {
    opacity: 1;
  }

  .feature-icon-wrapper {
    width: 60px;
    height: 60px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2.5rem;
    color: var(--card-accent);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .feature-card:hover .feature-icon-wrapper {
    background: var(--card-accent);
    color: #000;
    transform: translateY(-5px) rotate(8deg);
    box-shadow: 0 10px 20px -5px var(--card-accent);
  }

  .feature-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .feature-desc {
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 1.0625rem;
    font-weight: 450;
  }

  @media (max-width: 860px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
    .feature-card {
      padding: 2.5rem;
    }
  }
</style>
