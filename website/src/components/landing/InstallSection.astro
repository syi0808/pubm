---
const base = import.meta.env.BASE_URL;
---

<section class="install section-divider" id="install">
  <div class="install-container">
    <div class="install-header">
      <h2 class="gradient-text">Install once. Then just run <code>pubm</code>.</h2>
      <p>The default path is interactive: choose patch, minor, or major from the terminal, then let pubm handle the release pipeline.</p>
    </div>

    <div class="install-terminal glass-panel">
      <div class="terminal-header">
        <div class="terminal-dots">
          <span class="terminal-dot" style="background: #ff5f57;"></span>
          <span class="terminal-dot" style="background: #febc2e;"></span>
          <span class="terminal-dot" style="background: #28c840;"></span>
        </div>
        <div class="terminal-title">bash — install</div>
        <button class="copy-btn" aria-label="Copy commands">
          <svg class="icon-clipboard" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg class="icon-check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>
      <div class="terminal-body">
        <pre><code><span class="prompt">❯</span> npm i -g pubm
<span class="prompt">❯</span> pubm</code></pre>
      </div>
    </div>

    <div class="install-cta">
      <a href={`${base}/guides/quick-start`} class="btn-primary">
        Read the Docs
        <svg style="margin-left: 8px;" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="https://github.com/syi0808/pubm" target="_blank" rel="noopener" class="btn-ghost">View on GitHub</a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initInstall() {
    const section = document.querySelector('#install');
    if (!section) return;

    // Force absolute visibility first
    const reveals = section.querySelectorAll('.install-header h2, .install-header p, .install-terminal, .install-cta');
    gsap.set(reveals, { opacity: 1, visibility: 'visible', y: 0 });

    // Simple reveal timeline without SplitText for now to confirm visibility
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top 90%',
      }
    });

    tl.from('.install-header h2', {
      y: 30,
      opacity: 0,
      duration: 1,
      ease: 'expo.out'
    })
    .from('.install-header p', {
      y: 20,
      opacity: 0,
      duration: 0.8,
      ease: 'power2.out'
    }, '-=0.6')
    .from('.install-terminal', {
      rotateX: -15,
      y: 50,
      opacity: 0,
      duration: 1,
      ease: 'expo.out'
    }, '-=0.6')
    .from('.install-cta', {
      y: 20,
      opacity: 0,
      duration: 0.6
    }, '-=0.8');

    // Magnetic CTA Buttons
    const btns = section.querySelectorAll<HTMLElement>('.btn-primary, .btn-ghost');
    btns.forEach(btn => {
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(btn, {
          x: x * 0.3,
          y: y * 0.3,
          duration: 0.5,
          ease: 'power2.out'
        });
      });
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, {
          x: 0,
          y: 0,
          duration: 0.7,
          ease: 'elastic.out(1, 0.3)'
        });
      });
    });

    // Copy button
    const copyBtn = section.querySelector('.copy-btn') as HTMLButtonElement;
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const text = 'npm i -g pubm\npubm';
        navigator.clipboard.writeText(text).then(() => {
          const clipboard = copyBtn.querySelector('.icon-clipboard') as SVGElement;
          const check = copyBtn.querySelector('.icon-check') as SVGElement;
          clipboard.style.display = 'none';
          check.style.display = 'block';
          copyBtn.classList.add('copied');
          setTimeout(() => {
            clipboard.style.display = 'block';
            check.style.display = 'none';
            copyBtn.classList.remove('copied');
          }, 2000);
        });
      });
    }
  }

  // Ensure ScrollTrigger refreshes after everything is loaded
  window.addEventListener('load', () => {
    initInstall();
    ScrollTrigger.refresh();
  });
  document.addEventListener('astro:after-swap', () => {
    initInstall();
    ScrollTrigger.refresh();
  });
</script>

<style>
  .install {
    padding: 10rem 1.5rem;
    display: flex;
    justify-content: center;
    background: radial-gradient(circle at 50% 100%, rgba(6, 182, 212, 0.03) 0%, transparent 50%);
  }

  .install-container {
    max-width: 800px;
    width: 100%;
    text-align: center;
  }

  .install-header {
    margin-bottom: 4rem;
  }

  .install-header h2 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .install-header p {
    color: var(--text-muted);
    font-size: 1.25rem;
    overflow: hidden;
  }

  .install-terminal {
    max-width: 600px;
    margin: 0 auto;
    background: rgba(3, 7, 18, 0.8);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    text-align: left;
    will-change: transform, opacity;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .terminal-dots {
    display: flex;
    gap: 8px;
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.8;
  }

  .terminal-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    opacity: 0.5;
  }

  .terminal-body {
    padding: 1.5rem 2rem;
  }

  .terminal-body pre {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .prompt {
    color: var(--accent-cyan);
    margin-right: 0.5rem;
  }

  .comment {
    color: var(--text-muted);
    opacity: 0.7;
  }

  .copy-btn {
    margin-left: auto;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-muted);
    padding: 6px;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .copy-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-bright);
    background: rgba(255, 255, 255, 0.05);
  }

  .copy-btn.copied {
    border-color: var(--accent-green);
    color: var(--accent-green);
  }

  .btn-primary, .btn-ghost {
    will-change: transform;
  }

  .install-cta {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 4rem;
  }

  @media (max-width: 768px) {
    .install-header h2 {
      font-size: 2.5rem;
    }
    .install-cta {
      flex-direction: column;
      align-items: center;
    }
    .btn-primary, .btn-ghost {
      width: 100%;
      justify-content: center;
    }
  }
</style>
