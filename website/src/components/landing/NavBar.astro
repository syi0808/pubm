---
import type { LandingDictionary } from "../../i18n/landing";
import {
  getDocsPath,
  getLocalePath,
  localeLabels,
  locales,
  type SiteLocale,
} from "../../i18n/site";

interface Props {
  locale: SiteLocale;
  copy: LandingDictionary;
}

const { locale, copy } = Astro.props;
---

<nav class="navbar">
  <div class="navbar-inner glass-panel">
    <a href={getLocalePath(locale)} class="navbar-logo">
      <img src="logo_typo_with_transparent.png" alt="pubm" width="24" height="24" class="logo-img" />
      <span class="logo-text">pubm</span>
    </a>
    <div class="navbar-links">
      <a href={getDocsPath(locale)} class="nav-link">{copy.nav.docs}</a>
      <a href="https://github.com/syi0808/pubm" target="_blank" rel="noopener" class="nav-link">{copy.nav.github}</a>
      <label class="locale-picker">
        <span class="sr-only">Language</span>
        <select data-locale-switcher>
          {locales.map((entry) => (
            <option value={getLocalePath(entry)} selected={entry === locale}>
              {localeLabels[entry]}
            </option>
          ))}
        </select>
      </label>
      <a href={getDocsPath(locale)} class="btn-cta">{copy.nav.cta}</a>
    </div>
  </div>
</nav>

<script>
  const localeSwitcher = document.querySelector('[data-locale-switcher]') as HTMLSelectElement | null;
  localeSwitcher?.addEventListener('change', (event) => {
    const target = event.currentTarget as HTMLSelectElement;
    if (target.value) window.location.href = target.value;
  });

  const nav = document.querySelector('.navbar-inner');
  const handleScroll = () => {
    if (window.scrollY > 50) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  };
  window.addEventListener('scroll', handleScroll);
</script>

<style>
  .navbar {
    position: fixed;
    top: 1.5rem;
    left: 0;
    width: 100%;
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: 0 1.5rem;
    pointer-events: none;
  }

  .navbar-inner {
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    pointer-events: auto;
    border-radius: 999px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--shadow-lg);
  }

  .navbar-inner.scrolled {
    max-width: 700px;
    padding: 0.4rem 0.75rem;
    background: rgba(15, 23, 42, 0.85);
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: opacity 0.2s ease;
  }

  .navbar-logo:hover {
    opacity: 0.8;
  }

  .logo-img {
    filter: drop-shadow(0 0 8px rgba(34, 211, 238, 0.3));
  }

  .logo-text {
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .locale-picker select {
    appearance: none;
    border: 1px solid var(--border);
    background: rgba(15, 23, 42, 0.6);
    color: var(--text-primary);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    font: inherit;
    font-size: 0.8125rem;
  }

  .nav-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .btn-cta {
    background: var(--text-primary);
    color: #000;
    font-weight: 600;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.8125rem;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .btn-cta:hover {
    transform: scale(1.05);
    filter: brightness(0.9);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .navbar {
      top: 1rem;
    }
    .navbar-inner {
      padding: 0.4rem 0.8rem;
    }
    .logo-text {
      display: none;
    }
    .navbar-links {
      gap: 0.6rem;
    }
    .nav-link {
      font-size: 0.8rem;
    }
    .locale-picker select {
      max-width: 7rem;
      padding-inline: 0.65rem;
    }
  }
</style>
