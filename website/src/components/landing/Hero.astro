---
import TerminalPanel from './TerminalPanel.astro';

const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-grid">
    <div class="hero-content">
      <span class="hero-badge fade-in-up" style="animation-delay: 0s;">v0.2.12</span>
      <h1 class="fade-in-up" style="animation-delay: 0.1s;">
        Publish everywhere.<br />
        <span class="gradient-text">Roll back safely.</span>
      </h1>
      <p class="hero-sub fade-in-up" style="animation-delay: 0.2s;">
        Modern multi-registry publish orchestration for <span class="text-highlight">npm, jsr, crates.io</span>, and private registries.
      </p>
      <div class="hero-cta fade-in-up" style="animation-delay: 0.3s;">
        <a href={`${base}guides/quick-start`} class="btn-primary">
          Get Started 
          <svg style="margin-left: 8px;" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="https://github.com/syi0808/pubm" target="_blank" rel="noopener" class="btn-ghost">View on GitHub</a>
      </div>
    </div>
    <div class="hero-terminal fade-in-up" style="animation-delay: 0.4s;">
      <TerminalPanel />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 1.5rem 6rem;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: 1000px;
    height: 700px;
    background: radial-gradient(
      circle at center,
      rgba(6, 182, 212, 0.12) 0%,
      rgba(139, 92, 246, 0.08) 30%,
      transparent 70%
    );
    filter: blur(60px);
    animation: pulse-glow 8s infinite ease-in-out;
    pointer-events: none;
    z-index: 0;
  }

  .hero-grid {
    position: relative;
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 3rem;
    align-items: center;
    z-index: 1;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-right: 2rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(6, 182, 212, 0.08);
    border: 1px solid rgba(6, 182, 212, 0.15);
    border-radius: 9999px;
    padding: 0.35rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent-cyan);
    margin-bottom: 2rem;
    backdrop-filter: blur(4px);
  }

  h1 {
    font-family: var(--font-display);
    font-size: 4.5rem;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0 0 1.5rem;
  }

  .hero-sub {
    color: var(--text-muted);
    font-size: 1.35rem;
    max-width: 540px;
    margin: 0 0 3rem;
    line-height: 1.5;
  }

  .text-highlight {
    color: var(--text-primary);
    font-weight: 500;
  }

  .hero-cta {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .hero-terminal {
    display: flex;
    justify-content: flex-end;
    perspective: 1200px;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.4));
  }

  @media (max-width: 1100px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 5rem;
    }

    .hero-content {
      align-items: center;
      padding-right: 0;
    }

    h1 {
      font-size: 3.75rem;
    }

    .hero-sub {
      max-width: 600px;
    }

    .hero-cta {
      justify-content: center;
    }

    .hero-terminal {
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 7rem 1.25rem 4rem;
    }
    h1 {
      font-size: 2.75rem;
    }
    .hero-sub {
      font-size: 1.15rem;
    }
    .hero-cta {
      flex-direction: column;
      width: 100%;
    }
    .btn-primary, .btn-ghost {
      width: 100%;
      justify-content: center;
    }
  }
</style>
