---
import TerminalPanel from "./TerminalPanel.astro";
---

<section class="workflow-section section-divider" id="workflow">
  <div class="container">
    <div class="workflow-header">
      <div class="header-badge">Release Pipeline</div>
      <h2 class="display-title">One command does <span class="text-glow">everything.</span></h2>
      <p class="header-desc">
        Run <code>pubm</code> and it handles the rest — version prompts, preflight checks,
        testing, building, and publishing across every registry.
      </p>
    </div>
  </div>

  <div class="workflow-split" id="workflow-split">
    <!-- Left: scrolling text steps -->
    <div class="workflow-steps">
      <div class="workflow-step" data-step="0">
        <span class="step-number">01</span>
        <h3>Pick your version</h3>
        <p>
          Run <code>pubm</code> with no arguments. An interactive prompt lets you choose
          the next version — patch, minor, or major — before anything else happens.
        </p>
      </div>
      <div class="workflow-step" data-step="1">
        <span class="step-number">02</span>
        <h3>Preflight & auth</h3>
        <p>
          After you choose, pubm verifies the branch, working tree, remote sync,
          and registry credentials. Problems surface before any side effects.
        </p>
      </div>
      <div class="workflow-step" data-step="2">
        <span class="step-number">03</span>
        <h3>Test, build, tag</h3>
        <p>
          Your test suite runs, the build executes, and the version is bumped.
          A git commit and tag are created atomically — nothing is left half-done.
        </p>
      </div>
      <div class="workflow-step" data-step="3">
        <span class="step-number">04</span>
        <h3>Publish everywhere</h3>
        <p>
          All registries receive your package concurrently. Tags are pushed to origin.
          If anything fails, every change rolls back automatically.
        </p>
      </div>
    </div>

    <!-- Right: pinned terminal -->
    <div class="workflow-terminal">
      <TerminalPanel
        variant="workflow"
        mode="manual"
        panelClass="workflow-terminal-panel"
      />
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  let workflowCtx: ReturnType<typeof gsap.context> | null = null;

  function initWorkflow() {
    if (workflowCtx) workflowCtx.revert();

    workflowCtx = gsap.context(() => {
      const section = document.querySelector('#workflow');
      const splitEl = document.querySelector('#workflow-split');
      if (!section || !splitEl) return;

      const steps = gsap.utils.toArray<HTMLElement>('.workflow-step');
      const terminalPanel = splitEl.querySelector('pubm-terminal-player');
      const setTerminalFrame = (frameIndex: number) => {
        window.__pubmTerminalApi?.setFrame(terminalPanel, frameIndex);
      };

      // Header reveal
      const title = section.querySelector('.display-title');
      if (title) {
        const split = new SplitText(title, { type: 'words,chars' });
        gsap.from(split.chars, {
          scrollTrigger: { trigger: title, start: 'top 90%' },
          y: 20, opacity: 0, stagger: 0.02, duration: 0.8, ease: 'power3.out'
        });
      }

      gsap.from('.workflow-header .header-badge', {
        scrollTrigger: { trigger: section, start: 'top 85%' },
        opacity: 0, y: 20, duration: 0.8, ease: 'power3.out'
      });
      gsap.from('.workflow-header .header-desc', {
        scrollTrigger: { trigger: section, start: 'top 80%' },
        opacity: 0, y: 20, duration: 0.8, delay: 0.2, ease: 'power3.out'
      });

      ScrollTrigger.matchMedia({
        // Desktop: pinned split-screen
        '(min-width: 769px)': () => {
          const STEP_COUNT = steps.length;
          let activeStep = 0;

          steps.forEach((step, i) => {
            gsap.set(step, {
              opacity: i === 0 ? 1 : 0,
              y: i === 0 ? 0 : 40,
            });
          });

          setTerminalFrame(0);

          const syncStep = (nextStep: number) => {
            if (nextStep === activeStep) return;

            const previousStep = activeStep;
            activeStep = nextStep;

            gsap.to(steps[previousStep], {
              opacity: 0,
              y: -40,
              duration: 0.3,
              overwrite: true,
            });

            gsap.to(steps[nextStep], {
              opacity: 1,
              y: 0,
              duration: 0.3,
              overwrite: true,
            });

            setTerminalFrame(nextStep);
          };

          ScrollTrigger.create({
            trigger: splitEl,
            start: 'top top+=80',
            end: `+=${window.innerHeight * 3}`,
            pin: true,
            scrub: 1,
            anticipatePin: 1,
            onUpdate: (self) => {
              const nextStep = Math.min(
                STEP_COUNT - 1,
                Math.floor(self.progress * STEP_COUNT),
              );
              syncStep(nextStep);
            },
          });
        },

        // Mobile: stacked layout with simple reveals
        '(max-width: 768px)': () => {
          setTerminalFrame(steps.length - 1);

          // Simple fade-in for each step
          steps.forEach(step => {
            gsap.from(step, {
              scrollTrigger: { trigger: step, start: 'top 85%' },
              opacity: 0, y: 30, duration: 0.8, ease: 'power3.out'
            });
          });

          // Terminal fade-in
          gsap.from('.workflow-terminal', {
            scrollTrigger: { trigger: '.workflow-terminal', start: 'top 85%' },
            opacity: 0, y: 40, duration: 1, ease: 'power3.out'
          });
        }
      });
    });
  }

  if (document.readyState === 'complete') {
    initWorkflow();
  } else {
    window.addEventListener('load', initWorkflow);
  }
  document.addEventListener('astro:after-swap', initWorkflow);
</script>

<style>
  .workflow-section {
    padding: 12rem 1.5rem 4rem;
    background: var(--bg-primary);
    overflow: hidden;
  }

  .workflow-header {
    text-align: center;
    margin-bottom: 6rem;
  }

  .header-badge {
    display: inline-block;
    color: var(--accent-violet);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
    background: rgba(167, 139, 250, 0.08);
    padding: 0.4rem 1.25rem;
    border-radius: 999px;
    border: 1px solid rgba(167, 139, 250, 0.15);
  }

  .display-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }

  .header-desc {
    color: var(--text-muted);
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 450;
  }

  .header-desc code {
    font-family: var(--font-mono);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.95em;
  }

  /* Split layout */
  .workflow-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
    align-items: center;
    min-height: 80vh;
  }

  /* Left: step text */
  .workflow-steps {
    position: relative;
    min-height: 280px;
  }

  .workflow-step {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    padding-right: 2rem;
  }

  .workflow-step:first-child {
    position: relative;
    top: auto;
    transform: none;
  }

  .step-number {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.25rem;
    opacity: 0.7;
  }

  .workflow-step h3 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    line-height: 1.15;
    color: var(--text-primary);
  }

  .workflow-step p {
    color: var(--text-secondary);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.7;
    max-width: 480px;
    font-weight: 450;
  }

  .workflow-step code {
    font-family: var(--font-mono);
    color: var(--accent-cyan);
    font-weight: 600;
    font-size: 0.95em;
  }

  /* Right: terminal */
  .workflow-terminal {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .workflow-terminal :global(.workflow-terminal-panel) {
    max-width: 520px;
    width: 100%;
  }

  .workflow-terminal :global(.terminal-body) {
    min-height: 380px;
    font-size: 0.8rem;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .workflow-section {
      padding: 8rem 1.5rem 4rem;
    }

    .workflow-header {
      margin-bottom: 3rem;
    }

    .workflow-split {
      grid-template-columns: 1fr;
      gap: 3rem;
      min-height: auto;
    }

    .workflow-steps {
      min-height: auto;
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }

    .workflow-step {
      position: relative;
      top: auto;
      transform: none;
      padding-right: 0;
    }

    .workflow-terminal :global(.terminal-body) {
      min-height: auto;
      font-size: 0.72rem;
    }
  }
</style>
