---
---

<section class="workflow-section section-divider" id="workflow">
  <div class="container">
    <div class="workflow-header">
      <div class="header-badge">Release Pipeline</div>
      <h2 class="display-title">One command does <span class="text-glow">everything.</span></h2>
      <p class="header-desc">
        Run <code>pubm</code> and it handles the rest — version prompts, preflight checks,
        testing, building, and publishing across every registry.
      </p>
    </div>
  </div>

  <div class="workflow-split" id="workflow-split">
    <!-- Left: scrolling text steps -->
    <div class="workflow-steps">
      <div class="workflow-step" data-step="0">
        <span class="step-number">01</span>
        <h3>Pick your version</h3>
        <p>
          Run <code>pubm</code> with no arguments. An interactive prompt lets you choose
          the next version — patch, minor, or major — before anything else happens.
        </p>
      </div>
      <div class="workflow-step" data-step="1">
        <span class="step-number">02</span>
        <h3>Preflight & auth</h3>
        <p>
          After you choose, pubm verifies the branch, working tree, remote sync,
          and registry credentials. Problems surface before any side effects.
        </p>
      </div>
      <div class="workflow-step" data-step="2">
        <span class="step-number">03</span>
        <h3>Test, build, tag</h3>
        <p>
          Your test suite runs, the build executes, and the version is bumped.
          A git commit and tag are created atomically — nothing is left half-done.
        </p>
      </div>
      <div class="workflow-step" data-step="3">
        <span class="step-number">04</span>
        <h3>Publish everywhere</h3>
        <p>
          All registries receive your package concurrently. Tags are pushed to origin.
          If anything fails, every change rolls back automatically.
        </p>
      </div>
    </div>

    <!-- Right: pinned terminal -->
    <div class="workflow-terminal">
      <div class="wf-terminal glass-panel">
        <div class="wf-terminal-header">
          <div class="wf-terminal-dots">
            <span class="wf-dot" style="background: #ff5f57;"></span>
            <span class="wf-dot" style="background: #febc2e;"></span>
            <span class="wf-dot" style="background: #28c840;"></span>
          </div>
          <div class="wf-terminal-title">bash — pubm</div>
        </div>
        <div class="wf-terminal-body">
          <!-- Step 0: command + version prompt -->
          <div class="t-line" data-show="0"><span class="t-prompt">$</span> pubm</div>
          <div class="t-line" data-show="0">&nbsp;</div>
          <div class="t-line" data-show="0"><span class="t-cyan">?</span> Select version <span class="t-muted">(current: 1.2.3)</span></div>
          <div class="t-line" data-show="0"><span class="t-cyan">❯</span> <span class="t-selected">patch</span> <span class="t-muted">1.2.3 → 1.2.4</span></div>
          <div class="t-line" data-show="0">&nbsp;&nbsp;<span class="t-muted">minor  1.2.3 → 1.3.0</span></div>
          <div class="t-line" data-show="0">&nbsp;&nbsp;<span class="t-muted">major  1.2.3 → 2.0.0</span></div>

          <!-- Step 1: preflight + auth -->
          <div class="t-line" data-show="1">&nbsp;</div>
          <div class="t-line" data-show="1"><span class="t-check">✔</span> <span class="t-muted">Branch is</span> <span class="t-white">main</span></div>
          <div class="t-line" data-show="1"><span class="t-check">✔</span> <span class="t-muted">Working tree clean</span></div>
          <div class="t-line" data-show="1"><span class="t-check">✔</span> <span class="t-muted">Remote in sync</span></div>
          <div class="t-line" data-show="1">&nbsp;</div>
          <div class="t-line" data-show="1"><span class="t-check">✔</span> <span class="t-muted">npm</span> <span class="t-dots">·······</span> <span class="t-green">authenticated</span></div>
          <div class="t-line" data-show="1"><span class="t-check">✔</span> <span class="t-muted">jsr</span> <span class="t-dots">········</span> <span class="t-green">authenticated</span></div>

          <!-- Step 2: test, build, tag -->
          <div class="t-line" data-show="2">&nbsp;</div>
          <div class="t-line" data-show="2"><span class="t-check">✔</span> <span class="t-muted">Tests passed</span> <span class="t-muted">(42 specs, 0 failures)</span></div>
          <div class="t-line" data-show="2"><span class="t-check">✔</span> <span class="t-muted">Build succeeded</span></div>
          <div class="t-line" data-show="2"><span class="t-check">✔</span> <span class="t-muted">Version bumped</span> <span class="t-white">1.2.3 → 1.2.4</span></div>
          <div class="t-line" data-show="2"><span class="t-check">✔</span> <span class="t-muted">Git commit + tag</span> <span class="t-white">v1.2.4</span></div>

          <!-- Step 3: publish -->
          <div class="t-line" data-show="3">&nbsp;</div>
          <div class="t-line" data-show="3"><span class="t-cyan">⠋</span> <span class="t-cyan">Publishing to registries...</span></div>
          <div class="t-line" data-show="3">&nbsp;&nbsp;<span class="t-check">✔</span> <span class="t-muted">npm</span> <span class="t-dots">···········</span> <span class="t-green">published</span></div>
          <div class="t-line" data-show="3">&nbsp;&nbsp;<span class="t-check">✔</span> <span class="t-muted">jsr</span> <span class="t-dots">···········</span> <span class="t-green">published</span></div>
          <div class="t-line" data-show="3"><span class="t-check">✔</span> <span class="t-muted">Tags pushed to origin</span></div>
          <div class="t-line t-final" data-show="3">&nbsp;</div>
          <div class="t-line t-final" data-show="3"><span class="t-check">✔</span> <span class="t-green">Published to 2 registries — done</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  let workflowCtx: ReturnType<typeof gsap.context> | null = null;

  function initWorkflow() {
    if (workflowCtx) workflowCtx.revert();

    workflowCtx = gsap.context(() => {
      const section = document.querySelector('#workflow');
      const splitEl = document.querySelector('#workflow-split');
      if (!section || !splitEl) return;

      const steps = gsap.utils.toArray<HTMLElement>('.workflow-step');
      const allLines = gsap.utils.toArray<HTMLElement>('.t-line');

      // Header reveal
      const title = section.querySelector('.display-title');
      if (title) {
        const split = new SplitText(title, { type: 'words,chars' });
        gsap.from(split.chars, {
          scrollTrigger: { trigger: title, start: 'top 90%' },
          y: 20, opacity: 0, stagger: 0.02, duration: 0.8, ease: 'power3.out'
        });
      }

      gsap.from('.workflow-header .header-badge', {
        scrollTrigger: { trigger: section, start: 'top 85%' },
        opacity: 0, y: 20, duration: 0.8, ease: 'power3.out'
      });
      gsap.from('.workflow-header .header-desc', {
        scrollTrigger: { trigger: section, start: 'top 80%' },
        opacity: 0, y: 20, duration: 0.8, delay: 0.2, ease: 'power3.out'
      });

      ScrollTrigger.matchMedia({
        // Desktop: pinned split-screen
        '(min-width: 769px)': () => {
          const STEP_COUNT = steps.length;

          // Initial state: hide all terminal lines
          gsap.set(allLines, { opacity: 0, y: 8 });

          // Show step-0 lines immediately (will animate in with timeline)
          // All steps except first are hidden
          steps.forEach((step, i) => {
            if (i > 0) gsap.set(step, { opacity: 0, y: 40 });
          });

          // Show step-0 lines
          const step0Lines = allLines.filter(l => l.dataset.show === '0');
          gsap.set(step0Lines, { opacity: 1, y: 0 });

          // Main pinned timeline
          const tl = gsap.timeline({
            scrollTrigger: {
              trigger: splitEl,
              start: 'top top+=80',
              end: `+=${window.innerHeight * 3}`,
              pin: true,
              scrub: 1,
              anticipatePin: 1,
            }
          });

          // Build step transitions
          for (let i = 0; i < STEP_COUNT - 1; i++) {
            const nextStep = i + 1;
            const nextLines = allLines.filter(l => l.dataset.show === String(nextStep));

            // Fade out current step text
            tl.to(steps[i], { opacity: 0, y: -40, duration: 0.3 });

            // Fade in next step text
            tl.to(steps[nextStep], { opacity: 1, y: 0, duration: 0.3 }, '-=0.1');

            // Reveal next terminal lines with stagger
            tl.to(nextLines, {
              opacity: 1,
              y: 0,
              stagger: 0.04,
              duration: 0.15,
            }, '<+=0.05');

            // Add gap between transitions
            if (nextStep < STEP_COUNT - 1) {
              tl.to({}, { duration: 0.15 });
            }
          }
        },

        // Mobile: stacked layout with simple reveals
        '(max-width: 768px)': () => {
          // Show all lines
          gsap.set(allLines, { opacity: 1, y: 0 });

          // Simple fade-in for each step
          steps.forEach(step => {
            gsap.from(step, {
              scrollTrigger: { trigger: step, start: 'top 85%' },
              opacity: 0, y: 30, duration: 0.8, ease: 'power3.out'
            });
          });

          // Terminal fade-in
          gsap.from('.workflow-terminal', {
            scrollTrigger: { trigger: '.workflow-terminal', start: 'top 85%' },
            opacity: 0, y: 40, duration: 1, ease: 'power3.out'
          });
        }
      });
    });
  }

  if (document.readyState === 'complete') {
    initWorkflow();
  } else {
    window.addEventListener('load', initWorkflow);
  }
  document.addEventListener('astro:after-swap', initWorkflow);
</script>

<style>
  .workflow-section {
    padding: 12rem 1.5rem 4rem;
    background: var(--bg-primary);
    overflow: hidden;
  }

  .workflow-header {
    text-align: center;
    margin-bottom: 6rem;
  }

  .header-badge {
    display: inline-block;
    color: var(--accent-violet);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
    background: rgba(167, 139, 250, 0.08);
    padding: 0.4rem 1.25rem;
    border-radius: 999px;
    border: 1px solid rgba(167, 139, 250, 0.15);
  }

  .display-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }

  .header-desc {
    color: var(--text-muted);
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 450;
  }

  .header-desc code {
    font-family: var(--font-mono);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.95em;
  }

  /* Split layout */
  .workflow-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
    align-items: center;
    min-height: 80vh;
  }

  /* Left: step text */
  .workflow-steps {
    position: relative;
    min-height: 280px;
  }

  .workflow-step {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    padding-right: 2rem;
  }

  .workflow-step:first-child {
    position: relative;
    top: auto;
    transform: none;
  }

  .step-number {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.25rem;
    opacity: 0.7;
  }

  .workflow-step h3 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    line-height: 1.15;
    color: var(--text-primary);
  }

  .workflow-step p {
    color: var(--text-secondary);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.7;
    max-width: 480px;
    font-weight: 450;
  }

  .workflow-step code {
    font-family: var(--font-mono);
    color: var(--accent-cyan);
    font-weight: 600;
    font-size: 0.95em;
  }

  /* Right: terminal */
  .workflow-terminal {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .wf-terminal {
    max-width: 520px;
    width: 100%;
    background: rgba(3, 7, 18, 0.85);
    box-shadow:
      0 30px 60px rgba(0, 0, 0, 0.5),
      0 0 0 1px var(--border);
  }

  .wf-terminal-header {
    display: flex;
    align-items: center;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .wf-terminal-dots {
    display: flex;
    gap: 8px;
  }

  .wf-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.8;
  }

  .wf-terminal-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    opacity: 0.5;
  }

  .wf-terminal-body {
    padding: 1.25rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    min-height: 380px;
  }

  /* Terminal line styles */
  .t-line {
    margin-bottom: 0.15rem;
    white-space: nowrap;
  }

  .t-prompt { color: var(--accent-cyan); margin-right: 8px; }
  .t-check { color: var(--accent-green); margin-right: 6px; }
  .t-cyan { color: var(--accent-cyan); }
  .t-green { color: var(--accent-green); font-weight: 500; }
  .t-muted { color: var(--text-muted); }
  .t-white { color: var(--text-primary); }
  .t-dots { color: var(--border-bright); }
  .t-selected { color: var(--accent-cyan); font-weight: 600; }

  .t-final {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--border);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .workflow-section {
      padding: 8rem 1.5rem 4rem;
    }

    .workflow-header {
      margin-bottom: 3rem;
    }

    .workflow-split {
      grid-template-columns: 1fr;
      gap: 3rem;
      min-height: auto;
    }

    .workflow-steps {
      min-height: auto;
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }

    .workflow-step {
      position: relative;
      top: auto;
      transform: none;
      padding-right: 0;
    }

    .wf-terminal-body {
      min-height: auto;
      font-size: 0.8rem;
    }

    .t-line {
      white-space: pre-wrap;
      word-break: break-all;
    }
  }
</style>
