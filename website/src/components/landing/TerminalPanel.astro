  terminalFrames[1],
  terminalFrames[4],
  terminalFrames[7],
  terminalFrames[8],
];

const {
  variant = "hero",
  mode = "autoplay",
  initialFrame = 0,
  title = "zsh — pubm",
  panelClass = "",
} = Astro.props as Props;

const frames = variant === "workflow" ? workflowTerminalFrames : terminalFrames;
const normalizedInitialFrame = Math.max(
  0,
  Math.min(initialFrame, frames.length - 1),
);
const initialFrameData = frames[normalizedInitialFrame];
---

<pubm-terminal-player
  class={panelClass}
  data-pubm-terminal
  data-terminal-mode={mode}
  data-terminal-initial-frame={String(normalizedInitialFrame)}
>
  <div class="terminal glass-panel">
    <div class="terminal-header">
      <div class="terminal-dots">
        <span class="terminal-dot terminal-dot-close"></span>
        <span class="terminal-dot terminal-dot-minimize"></span>
        <span class="terminal-dot terminal-dot-maximize"></span>
      </div>
      <div class="terminal-title">{title}</div>
    </div>
    <div class="terminal-body" data-terminal-screen>
      {
        initialFrameData.lines.map((line) =>
          line.blank ? (
            <div class="terminal-row terminal-row-blank" aria-hidden="true">
              {" "}
            </div>
          ) : (
            <div class="terminal-row">
              {line.segments?.map((segment) => (
                <span
                  class:list={[
                    "terminal-segment",
                    segment.tone && `tone-${segment.tone}`,
                    segment.strong && "is-strong",
                    segment.underline && "is-underline",
                  ]}
                >
                  {segment.spinner ? "⠋" : segment.text}
                </span>
              ))}
            </div>
          ),
        )
      }
    </div>
    <script
      type="application/json"
      data-terminal-frames
      set:html={JSON.stringify(frames)}
    />
  </div>
</pubm-terminal-player>

<style>
  :global([data-pubm-terminal]) {
    display: block;
    width: 100%;
  }

  :global([data-pubm-terminal] .terminal) {
    max-width: 560px;
    width: 100%;
    background:
      linear-gradient(180deg, rgba(3, 7, 18, 0.92), rgba(2, 6, 23, 0.88)),
      radial-gradient(circle at top right, rgba(34, 211, 238, 0.08), transparent 32%);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.52),
      0 0 0 1px var(--border);
    transform: rotateX(2deg) rotateY(-2deg);
    transition: transform 0.5s ease;
  }

  :global([data-pubm-terminal] .terminal:hover) {
    transform: rotateX(0) rotateY(0);
  }

  :global([data-pubm-terminal] .terminal-header) {
    display: flex;
    align-items: center;
    padding: 0.8rem 1rem;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  :global([data-pubm-terminal] .terminal-dots) {
    display: flex;
    gap: 8px;
  }

  :global([data-pubm-terminal] .terminal-dot) {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.85;
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.2);
  }

  :global([data-pubm-terminal] .terminal-dot-close) {
    background: #ff5f57;
  }

  :global([data-pubm-terminal] .terminal-dot-minimize) {
    background: #febc2e;
  }

  :global([data-pubm-terminal] .terminal-dot-maximize) {
    background: #28c840;
  }

  :global([data-pubm-terminal] .terminal-title) {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.72rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    opacity: 0.7;
  }

  :global([data-pubm-terminal] .terminal-body) {
    padding: 1.2rem 1.35rem;
    min-height: 25rem;
    font-family: var(--font-mono);
    font-size: 0.77rem;
    line-height: 1.6;
    white-space: pre;
    overflow: hidden;
  }

  :global([data-pubm-terminal] .terminal-row) {
    display: block;
    min-height: 1.35em;
  }

  :global([data-pubm-terminal] .terminal-row.is-entering) {
    animation: terminal-row-in 180ms ease;
  }

  :global([data-pubm-terminal] .terminal-row-blank) {
    opacity: 0.28;
  }

  :global([data-pubm-terminal] .terminal-segment) {
    white-space: pre;
  }

  :global([data-pubm-terminal] .tone-plain) {
    color: var(--text-primary);
  }

  :global([data-pubm-terminal] .tone-dim) {
    color: var(--text-muted);
  }

  :global([data-pubm-terminal] .tone-prompt),
  :global([data-pubm-terminal] .tone-selected) {
    color: var(--accent-cyan);
  }

  :global([data-pubm-terminal] .tone-success) {
    color: var(--accent-green);
