---
type SegmentTone =
  | "plain"
  | "dim"
  | "prompt"
  | "success"
  | "warning"
  | "selected"
  | "summary";

interface Segment {
  text?: string;
  tone?: SegmentTone;
  strong?: boolean;
  underline?: boolean;
  spinner?: boolean;
}

interface TerminalLine {
  blank?: boolean;
  segments?: Segment[];
}

interface VersionPromptOption {
  label: string;
  value?: string;
}

type TerminalFrameAnimation =
  | {
      type: "task";
    }
  | {
      type: "prompt-command";
      commandBase: string;
      commandSuffix: string;
      erase?: boolean;
    }
  | {
      type: "prompt-select";
      options: VersionPromptOption[];
      selectionOrder: number[];
      selectionInterval?: number;
      commandText: string;
    };

interface TerminalFrame {
  duration: number;
  lines: TerminalLine[];
  animation?: TerminalFrameAnimation;
}

interface Props {
  variant?: "hero" | "workflow";
  mode?: "autoplay" | "manual";
  initialFrame?: number;
  title?: string;
  panelClass?: string;
}

