---
---

<div class="terminal glass-panel">
  <div class="terminal-header">
    <div class="terminal-dots">
      <span class="terminal-dot" style="background: #ff5f57;"></span>
      <span class="terminal-dot" style="background: #febc2e;"></span>
      <span class="terminal-dot" style="background: #28c840;"></span>
    </div>
    <div class="terminal-title">bash — pubm</div>
  </div>
  <div class="terminal-body">
    <div class="terminal-line" style="animation-delay: 0.6s;">
      <span class="prompt">$</span> pubm
    </div>
    <div class="terminal-line" style="animation-delay: 1.2s;">&nbsp;</div>
    <div class="terminal-line" style="animation-delay: 1.5s;">
      <span class="text-cyan">?</span> <span class="dim">Select version</span> <span class="dots">(current: 1.2.3)</span>
    </div>
    <div class="terminal-line" style="animation-delay: 1.8s;">
      <span class="prompt">❯</span> <span class="success">patch</span> <span class="dim">1.2.3 → 1.2.4</span>
    </div>
    <div class="terminal-line" style="animation-delay: 2.1s;">
      &nbsp;&nbsp;<span class="dim">minor 1.2.3 → 1.3.0</span>
    </div>
    <div class="terminal-line" style="animation-delay: 2.4s;">
      &nbsp;&nbsp;<span class="dim">major 1.2.3 → 2.0.0</span>
    </div>
    <div class="terminal-line" style="animation-delay: 2.8s;">
      <span class="check">✔</span> <span class="dim">Prerequisites validated</span>
    </div>
    <div class="terminal-line" style="animation-delay: 3.1s;">
      <span class="check">✔</span> <span class="dim">Registry connections verified</span>
    </div>
    <div class="terminal-line style-final" style="animation-delay: 3.5s;">
      <span class="spinner">◒</span> <span class="text-cyan">Publishing to registries...</span>
    </div>
    <div class="terminal-line style-final" style="animation-delay: 3.8s;">
      <span class="check">✔</span> <span class="success">Published to every configured registry</span>
    </div>
  </div>
</div>

<style>
  .terminal {
    max-width: 520px;
    width: 100%;
    background: rgba(3, 7, 18, 0.8);
    box-shadow: 
      0 20px 50px rgba(0, 0, 0, 0.5),
      0 0 0 1px var(--border);
    transform: rotateX(2deg) rotateY(-2deg);
    transition: transform 0.5s ease;
  }

  .terminal:hover {
    transform: rotateX(0) rotateY(0);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .terminal-dots {
    display: flex;
    gap: 8px;
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.8;
  }

  .terminal-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    opacity: 0.5;
  }

  .terminal-body {
    padding: 1.25rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    min-height: 280px;
  }

  @keyframes typeLine {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .terminal-line {
    animation: typeLine 0.3s ease-out forwards;
    opacity: 0;
    margin-bottom: 0.25rem;
  }

  .prompt { color: var(--accent-cyan); margin-right: 8px; }
  .check { color: var(--accent-green); margin-right: 8px; }
  .spinner { color: var(--accent-cyan); display: inline-block; animation: spin 1s linear infinite; margin-right: 8px; }
  .dim { color: var(--text-muted); }
  .success { color: var(--accent-green); font-weight: 500; }
  .text-cyan { color: var(--accent-cyan); }
  .dots { color: var(--border); }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .style-final {
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border);
  }
</style>
