#!/bin/bash
# Mock ping command for pubm demo environment
# Used by JsrConnector.ping() to check JSR connectivity

host="${@: -1}"

sleep "0.$(( RANDOM % 150 + 50 ))"

echo "PING ${host} (127.0.0.1): 56 data bytes"
echo "64 bytes from 127.0.0.1: icmp_seq=0 ttl=64 time=0.$(( RANDOM % 90 + 10 )) ms"
echo ""
echo "--- ${host} ping statistics ---"
echo "1 packets transmitted, 1 packets received, 0% packet loss"
echo "round-trip min/avg/max/stddev = 0.1/0.1/0.1/0.0 ms"
exit 0
